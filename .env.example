# =============================================================================
# Propera V2 — copy to `propera-v2/.env` (never commit `.env`)
# Dotenv loads `propera-v2/.env` from package root — see `src/config/env.js`
# =============================================================================
#
# +---------------------------------------------------------------------------+
# | VISUAL GUIDE — scan A / B / C                                             |
# +---------------------------------------------------------------------------+
#
#  (A) MUST SET IN .ENV  —  if missing, that slice does not work
#  ---------------------------------------------------------------------------
#   What you want                         | Set these in .env
#  ----------------------------------------|----------------------------------
#   HTTP server boots                       | (nothing required; PORT defaults)
#   Postgres brain (tickets, work_items)  | SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
#   Telegram inbound                        | TELEGRAM_BOT_TOKEN
#   Telegram webhook secret (if you use it) | TELEGRAM_WEBHOOK_SECRET  (matches Telegram secret_token)
#   Twilio SMS / WhatsApp webhooks + send   | TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, FROM numbers as needed
#   OpenAI intake (LLM or image OCR)        | OPENAI_API_KEY  +  flip INTAKE_LLM_ENABLED / INTAKE_MEDIA_OCR_ENABLED
#   POST /internal/cron/lifecycle-timers      | LIFECYCLE_CRON_SECRET  (non-empty) + header x-propera-cron-secret
#   “Manager / vendor” lane hints           | MANAGER_* / VENDOR_*  (optional; empty = no match)
#   Street vs unit address guard            | PROPERTY_ADDRESSES_JSON  (optional JSON)
#   Lock dashboard / ops APIs               | DASHBOARD_TOKEN  (optional)
#
#  (B) DEFAULT IF UNSET  —  you may omit; code uses this
#  ---------------------------------------------------------------------------
#   Variable                      | Default / behavior
#  ------------------------------|---------------------------------------------
#   PORT                          | 8080
#   NODE_ENV                      | development
#   CORE_ENABLED                  | ON  (only CORE_ENABLED=0 disables core)
#   PROPERA_SCHED_LATEST_HOUR     | 17
#   PROPERA_TZ, TZ                | host / Intl (set PROPERA_TZ to match property clocks)
#   INTAKE_COMPILE_TURN           | OFF
#   INTAKE_LLM_ENABLED            | OFF
#   INTAKE_MEDIA_OCR_ENABLED      | OFF
#   OPENAI_MODEL_EXTRACT          | gpt-4o-mini
#   OPENAI_MODEL_VISION           | gpt-4o-mini
#   PROPERA_METER_BATCH_VISION_MODEL | unset → same as OPENAI_MODEL_VISION
#   PROPERA_METER_REGISTER_LAST_DIGIT_ZERO | OFF → tens post-process off (prompt still states portfolio rule when passed); 1 → numeric append when digit count implies missing 0
#   PROPERA_METER_EXPECTED_REGISTER_DIGITS | unset → no fixed wheel count in prompt
#   TELEGRAM_OUTBOUND_ENABLED     | OFF  (must be exactly 1 to ack-send)
#   TWILIO_OUTBOUND_ENABLED       | OFF  (must be exactly 1 + SID/token)
#   DASHBOARD_ENABLED             | dev: UI on | prod: UI OFF unless =1
#   STRUCTURED_LOG                | logs ON  (only STRUCTURED_LOG=0 disables)
#   IDENTITY_API_ENABLED          | dev: ON unless 0 | prod: OFF unless 1
#
#  (C) IN POSTGRES POLICY  —  NOT .env  (table `property_policy`, GLOBAL + per-property)
#  ---------------------------------------------------------------------------
#   Business rules live here: lifecycle on/off, tenant-verify hours, staff pings,
#   schedule windows (SCHED_*), contact hours (CONTACT_*), ASSIGN_DEFAULT_OWNER, etc.
#   Code: `src/dal/lifecyclePolicyDal.js` — seeds: `supabase/migrations/014_*`, `015_*`, …
#   Do not duplicate these as env vars; tune in DB / migrations / ops sheet parity.
#
#  Boolean parsing: INTAKE_* flags → 1/true/yes/on vs 0/false/no/off; empty=OFF.
#                   TELEGRAM_OUTBOUND_ENABLED / TWILIO_OUTBOUND_ENABLED → exactly "1" to enable.
#
# =============================================================================

# --- Runtime ---
NODE_ENV=development
# HTTP listen port (default 8080). Keep 3000 free if you run propera-app (Next.js) locally.
PORT=8080

# --- Postgres / Supabase (tickets, work_items, event_log, policy, etc.) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only; never expose to browsers or clients

# --- Core brain (maintenance intake + finalize) ---
# Set to 0 to disable Postgres core path (tickets / work_items). Default on.
# CORE_ENABLED=1

# --- Turnover Engine (`GET/POST /api/portal/turnovers*`) ---
# Opt-in: only PROPERA_TURNOVER_ENGINE_ENABLED=1 exposes turnover APIs (otherwise 404).
# Use with propera-app NEXT_PUBLIC_PROPERA_TURNOVER_ENABLED=1 for UI + `/api/turnovers` proxy.
# PROPERA_TURNOVER_ENGINE_ENABLED=1
# Opt-in: unit occupancies / lifecycle APIs (`PROPERA_UNIT_LIFECYCLE_ENABLED=1`). See docs/UNIT_LIFECYCLE_BUILD_PLAN.md
# PROPERA_UNIT_LIFECYCLE_ENABLED=1
# Opt-in: only PROPERA_LEASING_ENGINE_ENABLED=1 exposes leasing APIs (otherwise 404).
# Use with propera-app NEXT_PUBLIC_PROPERA_LEASING_ENABLED=1 for UI + `/api/leasing` proxy.
# PROPERA_LEASING_ENGINE_ENABLED=1

# --- Open deck day chart (`GET /api/portal/tickets/day-curve`) ---
# Mobile tickets open-deck: hourly open snapshot + completed cumulative (8a–8p).
# Use with propera-app NEXT_PUBLIC_PROPERA_OPEN_DECK_DAY_CHART_ENABLED=1.
# PROPERA_OPEN_DECK_DAY_CHART_ENABLED=1

# Access Engine — amenity reservations + lock adapter (migration 057).
# Use with propera-app NEXT_PUBLIC_PROPERA_ACCESS_ENABLED=1 for /access UI.
# PROPERA_ACCESS_ENGINE_ENABLED=1
# ACCESS_CREDENTIAL_SECRET=   # long random — encrypts issued PINs at rest

# Tenant portal en/es — static UI uses profile; translate-on-write needs flag + OPENAI_API_KEY
# PROPERA_TENANT_I18N_ENABLED=1
# PROPERA_TENANT_TRANSLATE_MODEL=gpt-4o-mini

# --- Ops dashboard & APIs (same auth when DASHBOARD_TOKEN is set) ---
# GET /dashboard — flight-recorder UI
# GET /api/ops/event-log — `event_log` rows / threads
# GET /api/ops/lifecycle-timers — lifecycle timer health (needs migration 016)
# Unset DASHBOARD_ENABLED → on in development only; 0 = off; 1 = on in production too
# DASHBOARD_ENABLED=
# DASHBOARD_TOKEN=                    # optional: ?token=... or Authorization: Bearer

# --- Structured JSON logs to stdout (emit / emitTimed) ---
# Set to 0 to disable. See docs/STRUCTURED_LOGS.md
# STRUCTURED_LOG=

# --- Dev identity API (GET /api/dev/resolve-actor) ---
# In development, enabled unless IDENTITY_API_ENABLED=0. In production, off unless =1
# IDENTITY_API_ENABLED=

# =============================================================================
# Telegram (POST /webhooks/telegram)
# =============================================================================
# Webhook secret — must match Telegram setWebhook `secret_token` → header X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=
# Bot token — inbound adapter + optional outbound sendMessage
# TELEGRAM_BOT_TOKEN=
# Short ack after each handled Telegram message (requires TELEGRAM_BOT_TOKEN)
# TELEGRAM_OUTBOUND_ENABLED=0

# =============================================================================
# Twilio — SMS + WhatsApp (POST /webhooks/twilio, POST /webhooks/sms)
# =============================================================================
# One Twilio account (e.g. property manager / 10DLC-approved) for Verify + SMS:
#   TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN  →  Verify OTP + Messages API
#   TWILIO_VERIFY_SERVICE_SID               →  Verify service in THAT same account
#   TWILIO_SMS_FROM                         →  maintenance / tenant-agent inbound+outbound
#   TWILIO_BROADCAST_FROM                   →  Communications Engine notices (second number)
# Do not mix credentials from a different Twilio account than the phone numbers.
# Compliance STOP/START/HELP + sms_opt_out apply to SMS only (not WhatsApp/Telegram)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+15551234567
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_OUTBOUND_ENABLED=0
# Public HTTPS base for Settings → Channels webhook URLs (no trailing slash)
# PROPERA_PUBLIC_BASE_URL=https://api.usepropera.com
# Max voice agent (Twilio voice number → POST /webhooks/twilio/voice, WS /voice/stream)
# PROPERA_VOICE_ENABLED=0
# PROPERA_VOICE_MODEL=gpt-realtime-2
# PROPERA_VOICE_AGENT_VOICE=alloy
# PROPERA_VOICE_VAD_EAGERNESS=low
# PROPERA_VOICE_TURN_DETECTION=server_vad
# PROPERA_VOICE_SILENCE_MS=1200
# Requires: OPENAI_API_KEY, PROPERA_PUBLIC_BASE_URL (wss stream URL for Twilio)
# Twilio voice number webhook: https://<PUBLIC_BASE>/webhooks/twilio/voice
# Jarvis staff live voice (portal browser WS /voice/jarvis — not Twilio)
# JARVIS_VOICE_ENABLED=0
# Requires: OPENAI_API_KEY, PROPERA_PORTAL_TOKEN, JARVIS_ASK_ENABLED=1
# Inbound media OCR (INTAKE_MEDIA_OCR_ENABLED=1) uses the same SID+TOKEN to fetch MediaUrl* (Basic auth)

# --- Communication Engine (broadcast SMS — separate from maintenance number) ---
# Portal/API feature gate for `/api/communications/*`
# PROPERA_COMMUNICATION_ENGINE_ENABLED=1
# Dedicated Twilio number for tenant notices / campaigns
# TWILIO_BROADCAST_FROM=+15557654321
# Optional maintenance number in broadcast SMS footer + reply redirect copy.
# Leave unset to omit "For maintenance, call or text …" from broadcast footers (STOP line still added).
# Does not fall back to TWILIO_SMS_FROM — set explicitly when you want it shown.
# COMM_MAIN_NUMBER_DISPLAY=+15551234567
# Single-org V1 brand id stored on campaigns
# COMM_ORG_ID=grand
# PROPERA_DEFAULT_ORG_ID=grand
# Team & routing owns new maintenance assignee (staff_property_roles). Set 0 for legacy policy only.
# PROPERA_USE_RESPONSIBILITY_RESOLVER=1

# --- MO-4 company signup wizard (public /signup/company) ---
# PROPERA_ORG_SIGNUP_ENABLED=1
# PROPERA_ORG_SIGNUP_SECRET=change-me-long-random-string
# Hours to associate broadcast replies back to recent sent campaigns
# COMM_REPLY_WINDOW_HOURS=72
# Planned AI draft model for `/api/communications/draft`
# OPENAI_COMM_DRAFT_MODEL=gpt-4o-mini

# =============================================================================
# Timezone & schedule defaults (GAS parity)
# =============================================================================
# Canonical zone: when set, `env.js` also sets process.env.TZ so Date math matches labels.
# PROPERA_TZ=America/New_York
# Optional explicit TZ if you do not use PROPERA_TZ (Intl + Node local time)
# TZ=America/New_York
# GAS GLOBAL SCHED_LATEST_HOUR — "after 3pm" style window end (0–23, default 17)
# PROPERA_SCHED_LATEST_HOUR=17

# =============================================================================
# Address guard (street vs unit) — JSON array
# =============================================================================
# [{"num":"618","hints":["westfield"],"suffixes":["ave"]}, ...]
# PROPERTY_ADDRESSES_JSON=

# =============================================================================
# Router lanes — manager vs vendor (src/config/lanePolicy.js)
# =============================================================================
# Comma-separated Telegram numeric user ids (staff / manager). Alias: MANAGER_TG_IDS
# MANAGER_TELEGRAM_IDS=
# MANAGER_TG_IDS=
# Manager phone(s): last 10 digits used for matching. Single phone aliases: MANAGER_PHONE or ONCALL_NUMBER
# MANAGER_PHONE=
# ONCALL_NUMBER=
# MANAGER_PHONES=+15551234567,+15559876543
# Vendor lane — comma-separated last-10 digit patterns (fallback until vendor_contacts seeded)
# VENDOR_PHONE_LAST10_LIST=
# Outbound dispatch SMS when PM assigns vendor (1 = on, 0 = off)
# VENDOR_DISPATCH_ENABLED=1

# =============================================================================
# Intake — compile path + optional LLM + media OCR (src/config/env.js)
# =============================================================================
# GAS compileTurn / properaBuildIntakePackage fast path (1 | true | yes | on)
# INTAKE_COMPILE_TURN=0
#
# Portal Jarvis Ask — read-only staff Q&A on portal_chat (`jarvis_ask` mode)
# JARVIS_ASK_ENABLED=0
# JARVIS_ASK_LLM_ENABLED=0
# JARVIS_ASK_LLM_MODEL=gpt-4o-mini
#
# Portal Jarvis Plan — propose → confirm (`jarvis_plan` mode; slice 1: attach_ticket_cost)
# JARVIS_PLAN_ENABLED=0
#
# Jarvis tenant broadcast safety (propose_send_communication_campaign)
# PROPERA_JARVIS_COMM_DELIVERY_MODE=sms_only   — default; sms_and_portal | portal_only
# PROPERA_JARVIS_COMM_PORTFOLIO_ENABLED=0      — block all-properties blasts unless 1
#
# Jarvis operator thread state (`jarvis_operator_threads` — migration 070)
# JARVIS_THREAD_ENABLED=0
#
# Structured-signal LLM extraction (requires OPENAI_API_KEY)
# INTAKE_LLM_ENABLED=0
# OPENAI_API_KEY=
# OPENAI_MODEL_EXTRACT=gpt-4o-mini
#
# Vision OCR on images → `_mediaJson[].ocr_text` (Telegram file fetch + Twilio authenticated media fetch)
# Requires OPENAI_API_KEY; Twilio media fetch requires TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN
# INTAKE_MEDIA_OCR_ENABLED=0
# OPENAI_MODEL_VISION=gpt-4o-mini
#
# Expense bill scan (propera-app /financial → /api/portal/scan-expense)
# Provider: openai (default) | anthropic
# Financial capture via portal_chat_mode=financial (natural language expense/payment/charge)
# Requires PROPERA_FINANCE_ENABLED=1
# PROPERA_FINANCIAL_CAPTURE_ENABLED=1
# PROPERA_EXPENSE_SCAN_PROVIDER=openai
# Model override — defaults: gpt-4o-mini (openai) / claude-haiku-4-5-20251001 (anthropic)
# PROPERA_EXPENSE_SCAN_MODEL=gpt-4o-mini
# Unit asset nameplate OCR (Phase 4) — falls back to expense scan provider/model when unset:
# PROPERA_UNIT_ASSET_SCAN_PROVIDER=openai
# PROPERA_UNIT_ASSET_SCAN_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
#
# Inbound audio (Propera Chat / portal first) — `portal-chat-audio/` storage path + shared transcription
# INTAKE_AUDIO_ENABLED=0
# INTAKE_AUDIO_TRANSCRIPTION_ENABLED=0
# OPENAI_AUDIO_TRANSCRIPTION_ENABLED=0
# INTAKE_AUDIO_CHANNELS=portal
# INTAKE_AUDIO_MAX_SECONDS=120
# INTAKE_AUDIO_MAX_BYTES=25000000
# INTAKE_AUDIO_STORAGE_BUCKET=pm-attachments
# INTAKE_AUDIO_STORAGE_PATH_PREFIX=portal-chat-audio
# OPENAI_AUDIO_TRANSCRIPTION_MODEL=whisper-1
#
# Batch utility-meter runs — `/api/portal/meter-runs/.../process` vision extraction only.
# Unset → uses OPENAI_MODEL_VISION. For harder photos / digits, try gpt-4o (higher cost/latency than mini).
# PROPERA_METER_BATCH_VISION_MODEL=gpt-4o
# Whole-tens registers (last billing digit always 0): set to 1 to append a trailing 0 when digit-count hints a dropped wheel (needs accurate registerDigitCount from the model).
# PROPERA_METER_REGISTER_LAST_DIGIT_ZERO=1
# Expected visible odometer digit positions (e.g. 7); refinement pass + prompt consistency checks.
# PROPERA_METER_EXPECTED_REGISTER_DIGITS=7
# (openaiTransport.js: retries + 429 cooldown — no extra env knobs today)

# =============================================================================
# Lifecycle policy timers (migration: supabase/migrations/016_lifecycle_timers.sql)
# =============================================================================
# POST /internal/cron/lifecycle-timers — requires LIFECYCLE_CRON_SECRET non-empty or every request gets 401.
# Send header: x-propera-cron-secret: <same value as LIFECYCLE_CRON_SECRET>
# LIFECYCLE_CRON_SECRET=

# =============================================================================
# Outgate (future — not wired to env reads yet)
# =============================================================================
# Planned: LLM refinement of outbound copy. Deterministic path only today.
# OUTBOUND_AGENT_REFINE=0

# Phase 4 — property header (first contact/day), SMS STOP footer, Telegram Markdown (default on).
# OUTGATE_CHANNEL_RENDER=1

# Tenant Agent adapter (default off — legacy slot machine when 0)
# TENANT_AGENT_ENABLED=0
# TENANT_AGENT_LLM_ENABLED=0
# TENANT_AGENT_PROPERTY_ALLOWLIST=
# TENANT_AGENT_MAX_TURNS=12
# TENANT_AGENT_LLM_MODEL=gpt-4o-mini
# TENANT_AGENT_FALLBACK_TO_LEGACY=0
# TENANT_AGENT_CONVERSATION_TTL_HOURS=48

# =============================================================================
# Finance (ticket cost entries + chat `$$` capture)
# =============================================================================
# Master switch for finance DAL + portal ticket cost routes.
# PROPERA_FINANCE_ENABLED=1
# Ticket cost rows on tickets (`ticket_cost_entries`).
# PROPERA_FINANCE_TICKET_COSTS_ENABLED=1
# Chat / SMS / WA / Telegram `$$` expense capture (requires ticket costs).
# PROPERA_FINANCE_COST_CAPTURE_CHAT=1
# Optional rollout: comma-separated property codes (e.g. WESTGRAND,PENN). Empty = all.
# PROPERA_FINANCE_COST_CAPTURE_PROPERTIES=

# =============================================================================
# Resident tenant portal (/api/tenant/*)
# =============================================================================
# TENANT_JWT_SECRET=<long random string — separate from PROPERA_PORTAL_TOKEN>
# Tenant portal OTP — prefer Twilio Verify (no 10DLC campaign); falls back to TWILIO_SMS_FROM + tenant_otp_codes if unset
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Tenant portal Web Push (migration 083; same VAPID keys as staff portal push)
# PROPERA_PORTAL_PUSH_ENABLED=1 required; uses tenant_push_subscriptions table
#
# TENANT_OTP_TTL_MINUTES=10
# TENANT_OTP_MAX_ATTEMPTS=3
# TENANT_OTP_RATE_LIMIT_PER_15MIN=3
# TENANT_SESSION_DAYS=30
# SUPABASE_TENANT_DOCS_BUCKET=tenant-documents
# DEV_ORG_SUBDOMAIN=thegrand
# Local dev without SMS (NODE_ENV must not be production):
# TENANT_DEV_OTP_BYPASS=1
# TENANT_DEV_OTP_CODE=000000

# =============================================================================
# Portal bridge (propera-app merge + POST /webhooks/portal)
# =============================================================================
# Shared secret for GET /api/portal/* and POST /webhooks/portal (also alias PORTAL_API_TOKEN_PM).
# In development, if unset, portal read routes allow requests without a token.
# propera-app (Next): `next.config.ts` whitelists this file for PROPERA_PORTAL_TOKEN + default PROPERA_V2_API_URL from PORT.
# PROPERA_PORTAL_TOKEN=
# PORTAL_API_TOKEN_PM=
# PM ticket reassignment (`POST .../tickets/.../assignment`): set to 1 to log each request; `ticket_not_found` always logs one stderr line with decoded path + shape.
# PROPERA_PM_ASSIGN_DEBUG=1
# Portal actor gate: `1` = always require `Authorization: Bearer` (Supabase JWT) for auditable portal ticket actions; `0` = off; unset = on in production, off in development.
# PROPERA_PORTAL_ACTOR_JWT_REQUIRED=

# Staff portal Web Push (PWA lock-screen alerts). Requires migration 072_portal_push_subscriptions_v1.sql.
# Generate: npx web-push generate-vapid-keys
# PROPERA_PORTAL_PUSH_ENABLED=1
# PROPERA_VAPID_PUBLIC_KEY=
# PROPERA_VAPID_PRIVATE_KEY=
# PROPERA_VAPID_SUBJECT=mailto:ops@usepropera.com

# =============================================================================
# Index — every variable name used under propera-v2/src (grep `process.env` + env.js + lanePolicy)
# =============================================================================
# CORE_ENABLED DASHBOARD_ENABLED DASHBOARD_TOKEN IDENTITY_API_ENABLED INTAKE_COMPILE_TURN
# INTAKE_LLM_ENABLED INTAKE_MEDIA_OCR_ENABLED INTAKE_AUDIO_ENABLED INTAKE_AUDIO_TRANSCRIPTION_ENABLED
# INTAKE_AUDIO_CHANNELS INTAKE_AUDIO_MAX_SECONDS INTAKE_AUDIO_MAX_BYTES INTAKE_AUDIO_STORAGE_BUCKET
# INTAKE_AUDIO_STORAGE_PATH_PREFIX OPENAI_AUDIO_TRANSCRIPTION_ENABLED OPENAI_AUDIO_TRANSCRIPTION_MODEL
# INTAKE_LLM_ENABLED INTAKE_MEDIA_OCR_ENABLED LIFECYCLE_CRON_SECRET MANAGER_PHONE MANAGER_PHONES
# MANAGER_TELEGRAM_IDS MANAGER_TG_IDS NODE_ENV ONCALL_NUMBER OPENAI_API_KEY OPENAI_MODEL_EXTRACT
# OPENAI_MODEL_VISION OUTBOUND_AGENT_REFINE PORT PORTAL_API_TOKEN_PM PROPERTY_ADDRESSES_JSON PROPERA_PORTAL_TOKEN PROPERA_PORTAL_ACTOR_JWT_REQUIRED
# PROPERA_SCHED_LATEST_HOUR
# PROPERA_TZ STRUCTURED_LOG SUPABASE_SERVICE_ROLE_KEY SUPABASE_URL TELEGRAM_BOT_TOKEN
# TELEGRAM_OUTBOUND_ENABLED TELEGRAM_WEBHOOK_SECRET TWILIO_ACCOUNT_SID TWILIO_AUTH_TOKEN
# TWILIO_OUTBOUND_ENABLED TWILIO_SMS_FROM TWILIO_WHATSAPP_FROM TZ VENDOR_PHONE_LAST10_LIST
