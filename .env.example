# =============================================================================
# Propera V2 — copy to `propera-v2/.env` (never commit `.env`)
# Dotenv loads `propera-v2/.env` from package root — see `src/config/env.js`
# =============================================================================
#
# +---------------------------------------------------------------------------+
# | VISUAL GUIDE — scan A / B / C                                             |
# +---------------------------------------------------------------------------+
#
#  (A) MUST SET IN .ENV  —  if missing, that slice does not work
#  ---------------------------------------------------------------------------
#   What you want                         | Set these in .env
#  ----------------------------------------|----------------------------------
#   HTTP server boots                       | (nothing required; PORT defaults)
#   Postgres brain (tickets, work_items)  | SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
#   Telegram inbound                        | TELEGRAM_BOT_TOKEN
#   Telegram webhook secret (if you use it) | TELEGRAM_WEBHOOK_SECRET  (matches Telegram secret_token)
#   Twilio SMS / WhatsApp webhooks + send   | TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, FROM numbers as needed
#   OpenAI intake (LLM or image OCR)        | OPENAI_API_KEY  +  flip INTAKE_LLM_ENABLED / INTAKE_MEDIA_OCR_ENABLED
#   POST /internal/cron/lifecycle-timers      | LIFECYCLE_CRON_SECRET  (non-empty) + header x-propera-cron-secret
#   “Manager / vendor” lane hints           | MANAGER_* / VENDOR_*  (optional; empty = no match)
#   Street vs unit address guard            | PROPERTY_ADDRESSES_JSON  (optional JSON)
#   Lock dashboard / ops APIs               | DASHBOARD_TOKEN  (optional)
#
#  (B) DEFAULT IF UNSET  —  you may omit; code uses this
#  ---------------------------------------------------------------------------
#   Variable                      | Default / behavior
#  ------------------------------|---------------------------------------------
#   PORT                          | 8080
#   NODE_ENV                      | development
#   CORE_ENABLED                  | ON  (only CORE_ENABLED=0 disables core)
#   PROPERA_SCHED_LATEST_HOUR     | 17
#   PROPERA_TZ, TZ                | host / Intl (set PROPERA_TZ to match property clocks)
#   INTAKE_COMPILE_TURN           | OFF
#   INTAKE_LLM_ENABLED            | OFF
#   INTAKE_MEDIA_OCR_ENABLED      | OFF
#   OPENAI_MODEL_EXTRACT          | gpt-4o-mini
#   OPENAI_MODEL_VISION           | gpt-4o-mini
#   TELEGRAM_OUTBOUND_ENABLED     | OFF  (must be exactly 1 to ack-send)
#   TWILIO_OUTBOUND_ENABLED       | OFF  (must be exactly 1 + SID/token)
#   DASHBOARD_ENABLED             | dev: UI on | prod: UI OFF unless =1
#   STRUCTURED_LOG                | logs ON  (only STRUCTURED_LOG=0 disables)
#   IDENTITY_API_ENABLED          | dev: ON unless 0 | prod: OFF unless 1
#
#  (C) IN POSTGRES POLICY  —  NOT .env  (table `property_policy`, GLOBAL + per-property)
#  ---------------------------------------------------------------------------
#   Business rules live here: lifecycle on/off, tenant-verify hours, staff pings,
#   schedule windows (SCHED_*), contact hours (CONTACT_*), ASSIGN_DEFAULT_OWNER, etc.
#   Code: `src/dal/lifecyclePolicyDal.js` — seeds: `supabase/migrations/014_*`, `015_*`, …
#   Do not duplicate these as env vars; tune in DB / migrations / ops sheet parity.
#
#  Boolean parsing: INTAKE_* flags → 1/true/yes/on vs 0/false/no/off; empty=OFF.
#                   TELEGRAM_OUTBOUND_ENABLED / TWILIO_OUTBOUND_ENABLED → exactly "1" to enable.
#
# =============================================================================

# --- Runtime ---
NODE_ENV=development
# HTTP listen port (default 8080). Keep 3000 free if you run propera-app (Next.js) locally.
PORT=8080

# --- Postgres / Supabase (tickets, work_items, event_log, policy, etc.) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only; never expose to browsers or clients

# --- Core brain (maintenance intake + finalize) ---
# Set to 0 to disable Postgres core path (tickets / work_items). Default on.
# CORE_ENABLED=1

# --- Ops dashboard & APIs (same auth when DASHBOARD_TOKEN is set) ---
# GET /dashboard — flight-recorder UI
# GET /api/ops/event-log — `event_log` rows / threads
# GET /api/ops/lifecycle-timers — lifecycle timer health (needs migration 016)
# Unset DASHBOARD_ENABLED → on in development only; 0 = off; 1 = on in production too
# DASHBOARD_ENABLED=
# DASHBOARD_TOKEN=                    # optional: ?token=... or Authorization: Bearer

# --- Structured JSON logs to stdout (emit / emitTimed) ---
# Set to 0 to disable. See docs/STRUCTURED_LOGS.md
# STRUCTURED_LOG=

# --- Dev identity API (GET /api/dev/resolve-actor) ---
# In development, enabled unless IDENTITY_API_ENABLED=0. In production, off unless =1
# IDENTITY_API_ENABLED=

# =============================================================================
# Telegram (POST /webhooks/telegram)
# =============================================================================
# Webhook secret — must match Telegram setWebhook `secret_token` → header X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=
# Bot token — inbound adapter + optional outbound sendMessage
# TELEGRAM_BOT_TOKEN=
# Short ack after each handled Telegram message (requires TELEGRAM_BOT_TOKEN)
# TELEGRAM_OUTBOUND_ENABLED=0

# =============================================================================
# Twilio — SMS + WhatsApp (POST /webhooks/twilio, POST /webhooks/sms)
# =============================================================================
# Compliance STOP/START/HELP + sms_opt_out apply to SMS only (not WhatsApp/Telegram)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+15551234567
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_OUTBOUND_ENABLED=0
# Inbound media OCR (INTAKE_MEDIA_OCR_ENABLED=1) uses the same SID+TOKEN to fetch MediaUrl* (Basic auth)

# =============================================================================
# Timezone & schedule defaults (GAS parity)
# =============================================================================
# Canonical zone: when set, `env.js` also sets process.env.TZ so Date math matches labels.
# PROPERA_TZ=America/New_York
# Optional explicit TZ if you do not use PROPERA_TZ (Intl + Node local time)
# TZ=America/New_York
# GAS GLOBAL SCHED_LATEST_HOUR — "after 3pm" style window end (0–23, default 17)
# PROPERA_SCHED_LATEST_HOUR=17

# =============================================================================
# Address guard (street vs unit) — JSON array
# =============================================================================
# [{"num":"618","hints":["westfield"],"suffixes":["ave"]}, ...]
# PROPERTY_ADDRESSES_JSON=

# =============================================================================
# Router lanes — manager vs vendor (src/config/lanePolicy.js)
# =============================================================================
# Comma-separated Telegram numeric user ids (staff / manager). Alias: MANAGER_TG_IDS
# MANAGER_TELEGRAM_IDS=
# MANAGER_TG_IDS=
# Manager phone(s): last 10 digits used for matching. Single phone aliases: MANAGER_PHONE or ONCALL_NUMBER
# MANAGER_PHONE=
# ONCALL_NUMBER=
# MANAGER_PHONES=+15551234567,+15559876543
# Vendor lane stub — comma-separated last-10 digit patterns
# VENDOR_PHONE_LAST10_LIST=

# =============================================================================
# Intake — compile path + optional LLM + media OCR (src/config/env.js)
# =============================================================================
# GAS compileTurn / properaBuildIntakePackage fast path (1 | true | yes | on)
# INTAKE_COMPILE_TURN=0
#
# Structured-signal LLM extraction (requires OPENAI_API_KEY)
# INTAKE_LLM_ENABLED=0
# OPENAI_API_KEY=
# OPENAI_MODEL_EXTRACT=gpt-4o-mini
#
# Vision OCR on images → `_mediaJson[].ocr_text` (Telegram file fetch + Twilio authenticated media fetch)
# Requires OPENAI_API_KEY; Twilio media fetch requires TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN
# INTAKE_MEDIA_OCR_ENABLED=0
# OPENAI_MODEL_VISION=gpt-4o-mini
# (openaiTransport.js: retries + 429 cooldown — no extra env knobs today)

# =============================================================================
# Lifecycle policy timers (migration: supabase/migrations/016_lifecycle_timers.sql)
# =============================================================================
# POST /internal/cron/lifecycle-timers — requires LIFECYCLE_CRON_SECRET non-empty or every request gets 401.
# Send header: x-propera-cron-secret: <same value as LIFECYCLE_CRON_SECRET>
# LIFECYCLE_CRON_SECRET=

# =============================================================================
# Outgate (future — not wired to env reads yet)
# =============================================================================
# Planned: LLM refinement of outbound copy. Deterministic path only today.
# OUTBOUND_AGENT_REFINE=0

# =============================================================================
# Portal bridge (propera-app merge + POST /webhooks/portal)
# =============================================================================
# Shared secret for GET /api/portal/* and POST /webhooks/portal (also alias PORTAL_API_TOKEN_PM).
# In development, if unset, portal read routes allow requests without a token.
# propera-app (Next): `next.config.ts` whitelists this file for PROPERA_PORTAL_TOKEN + default PROPERA_V2_API_URL from PORT.
# PROPERA_PORTAL_TOKEN=
# PORTAL_API_TOKEN_PM=

# =============================================================================
# Index — every variable name used under propera-v2/src (grep `process.env` + env.js + lanePolicy)
# =============================================================================
# CORE_ENABLED DASHBOARD_ENABLED DASHBOARD_TOKEN IDENTITY_API_ENABLED INTAKE_COMPILE_TURN
# INTAKE_LLM_ENABLED INTAKE_MEDIA_OCR_ENABLED LIFECYCLE_CRON_SECRET MANAGER_PHONE MANAGER_PHONES
# MANAGER_TELEGRAM_IDS MANAGER_TG_IDS NODE_ENV ONCALL_NUMBER OPENAI_API_KEY OPENAI_MODEL_EXTRACT
# OPENAI_MODEL_VISION OUTBOUND_AGENT_REFINE PORT PORTAL_API_TOKEN_PM PROPERTY_ADDRESSES_JSON PROPERA_PORTAL_TOKEN
# PROPERA_SCHED_LATEST_HOUR
# PROPERA_TZ STRUCTURED_LOG SUPABASE_SERVICE_ROLE_KEY SUPABASE_URL TELEGRAM_BOT_TOKEN
# TELEGRAM_OUTBOUND_ENABLED TELEGRAM_WEBHOOK_SECRET TWILIO_ACCOUNT_SID TWILIO_AUTH_TOKEN
# TWILIO_OUTBOUND_ENABLED TWILIO_SMS_FROM TWILIO_WHATSAPP_FROM TZ VENDOR_PHONE_LAST10_LIST
