# Copy to .env and fill in locally (never commit .env)

NODE_ENV=development
# V2 API — use 8080 locally; keep 3000 for propera-app (Next.js)
PORT=8080

# Core intake + finalize to Postgres (tickets / work_items). Set to 0 to disable.
# CORE_ENABLED=1

# Supabase (after you create a project — see docs/OUTSIDE_CURSOR.md)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (server only; never in frontend)

# Ops dashboard — tenant-thread view of `event_log` (GET /dashboard, GET /api/ops/event-log)
# In development, dashboard is ON by default. Use http://127.0.0.1:8080/dashboard (not https).
# DASHBOARD_ENABLED=0   # force off | DASHBOARD_ENABLED=1 force on (e.g. production)
# DASHBOARD_TOKEN=   # optional shared secret — ?token=... on URL or Authorization: Bearer

# Structured JSON logs to terminal (set to 0 to disable)
# STRUCTURED_LOG=1

# Dev identity API: off in production unless set to 1
# IDENTITY_API_ENABLED=0

# Telegram webhook — optional secret (setWebhook secret_token → header X-Telegram-Bot-Api-Secret-Token)
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OUTBOUND_ENABLED=1   # optional: short Telegram ack after each message (needs BOT_TOKEN)

# Schedule parser — match GAS script TZ (`Session.getScriptTimeZone`) so "tomorrow" + local hours match production.
# When set, the server also assigns `TZ` so `Date` math and tenant-facing labels stay aligned (avoids e.g. "1–4 PM" for "tomorrow morning").
# PROPERA_TZ=America/New_York
# GAS ppGet GLOBAL SCHED_LATEST_HOUR (default 17) — "after 3pm" window end
# PROPERA_SCHED_LATEST_HOUR=17

# GAS PROPERTY_ADDRESSES — JSON array: [{"num":"618","hints":["westfield"],"suffixes":["ave"]},...]
# Prevents street numbers from being parsed as unit numbers. See docs/PORTING_FROM_GAS.md
# PROPERTY_ADDRESSES_JSON=

# Lane policy (same idea as GAS script properties — manager / vendor routing)
# MANAGER_TELEGRAM_IDS=123456789,987654321
# MANAGER_PHONES=+15551234567
# VENDOR_PHONE_LAST10_LIST=5551234567

# GAS `compileTurn_` / `properaBuildIntakePackage_` (maintenance fast path)
# INTAKE_COMPILE_TURN=1   # 1 / true / yes / on — compile path; restart after change
# Note: variables already set in the shell/OS take precedence over this file (dotenv does not override).
# OPENAI_API_KEY=         # required only if INTAKE_LLM_ENABLED=1 (structured JSON extraction)
# INTAKE_LLM_ENABLED=0    # 1 = call OpenAI for structured signal when key is set
# OPENAI_MODEL_EXTRACT=gpt-4o-mini   # GAS uses gpt-4.1-mini in script; any chat JSON model works

# Later: Twilio validation (Phase 2)
# TWILIO_AUTH_TOKEN=
