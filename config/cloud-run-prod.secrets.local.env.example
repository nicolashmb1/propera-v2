# Copy to cloud-run-prod.secrets.local.env and paste values from propera-v2/.env
# Then: npm run cloud-run:sync-prod-secrets
#
# NEVER commit cloud-run-prod.secrets.local.env

# --- Already on Cloud Run (update version if value changed) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PROPERA_PORTAL_TOKEN=
LIFECYCLE_CRON_SECRET=

# --- Add when features must work on prod brain ---
OPENAI_API_KEY=
TENANT_JWT_SECRET=
SEAM_API_KEY=
ACCESS_CREDENTIAL_SECRET=
PROPERA_ORG_SIGNUP_SECRET=

# --- Phase 5 channel cutover ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Push notifications ---
PROPERA_VAPID_PUBLIC_KEY=
PROPERA_VAPID_PRIVATE_KEY=
