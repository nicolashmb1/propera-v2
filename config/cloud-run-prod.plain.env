# Plain env vars for Cloud Run propera-v2-prod (non-secrets).
# Sync from propera-v2/.env â€” edit here, then: npm run cloud-run:sync-prod-env
# Secrets live in Secret Manager (see config/cloud-run-prod.secrets.env.example).

NODE_ENV=production
PROPERA_TZ=America/New_York
PROPERA_DEFAULT_ORG_ID=grand
COMM_ORG_ID=grand

# Public base for voice links, webhooks, cron callbacks (NOT ngrok on prod)
PROPERA_PUBLIC_BASE_URL=https://propera-v2-prod-438117417981.us-east1.run.app
PROPERA_LIFECYCLE_CRON_URL=https://propera-v2-prod-438117417981.us-east1.run.app/internal/cron/lifecycle-timers

# Spine
CORE_ENABLED=1
PROPERA_USE_RESPONSIBILITY_RESOLVER=1
DASHBOARD_ENABLED=1

# Intake / media
INTAKE_COMPILE_TURN=1
INTAKE_LLM_ENABLED=1
INTAKE_MEDIA_OCR_ENABLED=1
INTAKE_AUDIO_ENABLED=1
INTAKE_AUDIO_TRANSCRIPTION_ENABLED=1
OPENAI_AUDIO_TRANSCRIPTION_ENABLED=1
OPENAI_AUDIO_TRANSCRIPTION_MODEL=whisper-1
OPENAI_MODEL_EXTRACT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o-mini

# Meters
PROPERA_METER_REGISTER_LAST_DIGIT_ZERO=1
PROPERA_METER_BATCH_VISION_MODEL=gpt-4o-mini
PROPERA_METER_EXPECTED_REGISTER_DIGITS=7

# Module engines (pair with propera-app NEXT_PUBLIC_*)
PROPERA_ACCESS_ENGINE_ENABLED=1
PROPERA_TURNOVER_ENGINE_ENABLED=1
PROPERA_UNIT_LIFECYCLE_ENABLED=1
PROPERA_LEASING_ENGINE_ENABLED=1
PROPERA_FINANCE_ENABLED=1
PROPERA_FINANCE_TICKET_COSTS_ENABLED=1
PROPERA_FINANCE_LEDGER_ENABLED=1
PROPERA_FINANCE_COST_CAPTURE_CHAT=1
PROPERA_FINANCIAL_CAPTURE_ENABLED=1
PROPERA_OPEN_DECK_DAY_CHART_ENABLED=1
PROPERA_COMMUNICATION_ENGINE_ENABLED=1
PROPERA_CONFLICT_MEDIATION_ENABLED=1
PROPERA_ORG_SIGNUP_ENABLED=1
PROPERA_PORTAL_PUSH_ENABLED=1
PROPERA_TENANT_I18N_ENABLED=1
VENDOR_DISPATCH_ENABLED=0

# Tenant agent
TENANT_AGENT_ENABLED=1
TENANT_AGENT_LLM_ENABLED=1

# Jarvis
JARVIS_ASK_ENABLED=1
JARVIS_REASON_ENABLED=1
JARVIS_PLAN_ENABLED=1
JARVIS_THREAD_ENABLED=1
JARVIS_ASK_LLM_ENABLED=1
JARVIS_VOICE_ENABLED=1
PROPERA_JARVIS_AGENT_NAME=Jarvis
PROPERA_JARVIS_SETTINGS_ADMIN_EMAILS=nicolas.hmb1@gmail.com

# Voice (Max)
PROPERA_VOICE_ENABLED=1
PROPERA_VOICE_MODEL=gpt-realtime-2
PROPERA_VOICE_AGENT_VOICE=cedar
PROPERA_VOICE_AGENT_NAME=Max
PROPERA_VOICE_SPEAKING_STYLE=neutral
PROPERA_VOICE_VAD_EAGERNESS=low
PROPERA_VOICE_TURN_DETECTION=server_vad
PROPERA_VOICE_SILENCE_MS=1200

# Expense scan
PROPERA_EXPENSE_SCAN_PROVIDER=openai
PROPERA_EXPENSE_SCAN_MODEL=gpt-4o-mini

# Channels (flags; credentials are secrets â€” add when webhooks cut over)
TELEGRAM_OUTBOUND_ENABLED=1
TWILIO_OUTBOUND_ENABLED=1
TWILIO_BROADCAST_FROM=+19085880289
# Office number in broadcast auto-replies ("contact X office at …"). Falls back to TWILIO_SMS_FROM if unset.
# COMM_MAIN_NUMBER_DISPLAY=+1XXXXXXXXXX
COMM_REPLY_WINDOW_HOURS=72

PROPERA_VAPID_SUBJECT=mailto:propera@usepropera.com
DEV_ORG_SUBDOMAIN=thegrand