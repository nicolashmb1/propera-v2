# Map Cloud Run env var name → Secret Manager secret name (prod).
# Values live in cloud-run-prod.secrets.local.env (gitignored) — copy from propera-v2/.env
#
# Format: ENV_VAR=secret-manager-name

SUPABASE_URL=propera-v2-prod-supabase-url
SUPABASE_SERVICE_ROLE_KEY=propera-v2-prod-supabase-service-role
PROPERA_PORTAL_TOKEN=propera-v2-prod-portal-token
LIFECYCLE_CRON_SECRET=propera-v2-prod-lifecycle-cron-secret

OPENAI_API_KEY=propera-v2-prod-openai-api-key
TENANT_JWT_SECRET=propera-v2-prod-tenant-jwt-secret
SEAM_API_KEY=propera-v2-prod-seam-api-key
ACCESS_CREDENTIAL_SECRET=propera-v2-prod-access-credential-secret
PROPERA_ORG_SIGNUP_SECRET=propera-v2-prod-org-signup-secret

TELEGRAM_BOT_TOKEN=propera-v2-prod-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=propera-v2-prod-telegram-webhook-secret

TWILIO_ACCOUNT_SID=propera-v2-prod-twilio-account-sid
TWILIO_AUTH_TOKEN=propera-v2-prod-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=propera-v2-prod-twilio-verify-sid

PROPERA_VAPID_PUBLIC_KEY=propera-v2-prod-vapid-public-key
PROPERA_VAPID_PRIVATE_KEY=propera-v2-prod-vapid-private-key
