# Secret Manager bindings for propera-v2-prod (NOT plain env vars).
# Create each secret in GCP, then mount on Cloud Run → Variables & secrets → Reference a secret.
#
# Already wired on first deploy:
#   SUPABASE_URL                    ← propera-v2-prod-supabase-url
#   SUPABASE_SERVICE_ROLE_KEY       ← propera-v2-prod-supabase-service-role
#   PROPERA_PORTAL_TOKEN            ← propera-v2-prod-portal-token
#   LIFECYCLE_CRON_SECRET           ← propera-v2-prod-lifecycle-cron-secret
#
# Add from local .env when features must work on Cloud Run prod:

OPENAI_API_KEY=                    # Jarvis LLM, intake, OCR, voice, expense scan
TENANT_JWT_SECRET=                 # Tenant portal JWT
SEAM_API_KEY=                      # Access Engine lock adapter
ACCESS_CREDENTIAL_SECRET=          # Encrypted amenity PINs (optional)

TELEGRAM_BOT_TOKEN=                # Phase 5 — when Telegram webhook → Cloud Run
TELEGRAM_WEBHOOK_SECRET=           # optional

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_SMS_FROM=
TWILIO_BROADCAST_FROM=             # or plain env if not sensitive

PROPERA_VAPID_PUBLIC_KEY=
PROPERA_VAPID_PRIVATE_KEY=
PROPERA_VAPID_SUBJECT=mailto:propera@usepropera.com

PROPERA_ORG_SIGNUP_SECRET=

# Suggested Secret Manager names (prod):
#   propera-v2-prod-openai-api-key
#   propera-v2-prod-tenant-jwt-secret
#   propera-v2-prod-seam-api-key
#   propera-v2-prod-twilio-auth-token
#   etc.
