{
  "name": "propera-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Propera V2 runtime (Node) — parallel to GAS; production cutover is later",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:production": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test tests/*.test.js tests/dal/*.test.js tests/tenantAgent/*.test.js tests/scenarios/*.test.js tests/scenarios/access/*.test.js tests/vendor/*.test.js tests/agentContract/*.test.js tests/access/*.test.js tests/voice/*.test.js tests/agent/proposals/*.test.js tests/agent/jarvisReason/*.test.js",
    "test:integration": "node --test tests/integration/staffCaptureCrossChannel.test.js",
    "cloud-run:deploy-prod": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloud-run-prod.ps1",
    "cloud-run:deploy-staging": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloud-run-staging.ps1",
    "cloud-run:sync-prod-env": "powershell -ExecutionPolicy Bypass -File scripts/sync-cloud-run-prod-env.ps1",
    "cloud-run:sync-prod-secrets": "powershell -ExecutionPolicy Bypass -File scripts/sync-cloud-run-prod-secrets.ps1",
    "cloud-run:bootstrap-from-local-env": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-cloud-run-prod-from-local-env.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jpeg-js": "^0.4.4",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "seam": "^1.205.0",
    "stripe": "^17.7.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  }
}
