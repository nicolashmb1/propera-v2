# Propera Telegram Ingress Proxy — env template
# Copy to .env.local (Vercel) or set in Vercel Project Settings → Environment Variables

# Required: Apps Script Web App exec URL (doPost receives the forwarded body)
PROPERA_TELEGRAM_FORWARD_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Optional: if set, incoming requests must send this value in header X-Webhook-Secret or query ?secret=
PROPERA_PROXY_SECRET=
